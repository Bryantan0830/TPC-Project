<Window x:Class="ParallelKMeansMRI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parallel K-Means MRI Segmentation" Height="700" Width="1000"
        Background="#F3F4F6">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Controls -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Text="Select Image" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ImageComboBox" SelectedIndex="0" Margin="0,0,0,15" Padding="5">
                    <ComboBoxItem Content="Cancer MRI" />
                    <ComboBoxItem Content="Healthy MRI" />
                </ComboBox>

                <TextBlock Text="Select Hardware (ILGPU)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="HardwareComboBox" Margin="0,0,0,20" Padding="5">
                </ComboBox>

                <Button x:Name="RunButton" Content="Run Benchmark" Background="#2563EB" Foreground="White" 
                        FontWeight="Bold" Padding="10" Click="RunButton_Click" Cursor="Hand"/>
                
                <TextBlock x:Name="StatusText" Text="Ready" Margin="0,15,0,0" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Right Panel: Visuals & Results -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Images -->
            <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,10">
                <Border Background="White" CornerRadius="8" Margin="0,0,5,0" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2" />
                    </Border.Effect>
                    <Grid>
                        <TextBlock Text="Original" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="SemiBold"/>
                        <Image x:Name="OriginalImage" Margin="0,25,0,0" Stretch="Uniform"/>
                    </Grid>
                </Border>
                <Border Background="White" CornerRadius="8" Margin="5,0,0,0" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2" />
                    </Border.Effect>
                    <Grid>
                        <TextBlock Text="Segmented Output" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="SemiBold"/>
                        <Image x:Name="SegmentedImage" Margin="0,25,0,0" Stretch="Uniform"/>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Results Table -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
                <Grid>
                    <TextBlock Text="Benchmark Results" FontWeight="SemiBold" Margin="0,0,0,10" VerticalAlignment="Top"/>
                    <DataGrid x:Name="ResultsDataGrid" Margin="0,25,0,0" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Algorithm" Binding="{Binding AlgorithmName}" Width="*" />
                            <DataGridTextColumn Header="Time (ms)" Binding="{Binding TimeMs}" Width="100" />
                            <DataGridTextColumn Header="Speedup" Binding="{Binding Speedup, StringFormat={}{0:F2}x}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
